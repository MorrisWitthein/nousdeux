# Copy to .env.local (gitignored) for local development
VITE_API_URL=http://localhost:8080

# API env vars (set in your shell or .env when running `go run ./api`)
# DB_DSN=postgres://nousdeux:nousdeux@localhost:5432/nousdeux
# JWT_SECRET=changeme
# USERS={"max":"<bcrypt-hash>","lena":"<bcrypt-hash>"}
